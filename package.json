{
  "name": "hgz-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build  --watch",
    "node": "tsc && DEBUG=* NODE_ENV=development node --trace-warnings --loader ts-node/esm src/_server/index.ts --watch",
    "n": "DEBUG=* NODE_ENV=development node --trace-warnings --loader ts-node/esm src/_server/index.ts --watch",
    "vite-node": "vite-node",
    "prod": "vite preview",
    "test": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@apollo/client": "^3.8.7",
    "@apollo/server": "^4.9.5",
    "@types/express": "^4.17.20",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "msw": "^2.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serve-favicon": "^2.5.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "ts-node": "^10.9.1",
    "vitest": "^0.34.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@types/cors": "^2.8.15",
    "@types/debug": "^4.1.10",
    "@types/react": "^18.2.34",
    "@types/react-dom": "^18.2.14",
    "@types/serve-favicon": "^2.5.6",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "@vitejs/plugin-react": "^4.1.1",
    "debug": "^4.3.4",
    "eslint": "^8.52.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jsdom": "^22.1.0",
    "testing": "link:@apollo/client/testing",
    "typescript": "^5.2.2",
    "vite": "^4.5.0"
  }
}
